# Telegram Bot
TELEGRAM_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.6-plus:free
BOT_LANGUAGE=id
AUTO_DETECT_LANG=true

# Knowledge Base
KNOWLEDGE_DB=knowledge_base.db

# Twitter/X API (optional)
TWITTER_BEARER_TOKEN=
TRUSTED_TWITTER_ACCOUNTS=

# On-chain API Keys (optional)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
SOLANAFM_API_KEY=

# Logging
LOG_DIR=logs
LOG_FILE=agent_activity.log

# Whale Alert Thresholds (in native token units)
ETH_WHALE_THRESHOLD=1000
BSC_WHALE_THRESHOLD=500000
SOL_WHALE_THRESHOLD=500000

# Poll interval in seconds
WHALE_POLL_INTERVAL=1800

# Schedule Settings (Daily News)
SCHEDULE_ENABLED=true
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=30
SCHEDULE_TIMEZONE=Asia/Makassar
SCHEDULE_CHAT_ID=

# Coin Scanner Settings
SCAN_ENABLED=true
SCAN_INTERVAL_MINUTES=360
SCAN_MIN_VOLUME_USD=100000
SCAN_MIN_PRICE_CHANGE=10
SCAN_CHAT_ID=

# Solana Smart Wallet Scanner
SOLANA_ENABLED=false
SOLANA_CHAT_ID=
SOLANA_MIN_TRADE_VALUE=10
SOLANA_SCAN_INTERVAL=180

# GMGN Settings (Solana Memecoin Scanner)
GMGN_ENABLED=true

# Backtest Settings
BACKTEST_ENABLED=true
BACKTEST_HOUR=22
BACKTEST_MINUTE=0
BACKTEST_CHAT_ID=
BACKTEST_SUCCESS_THRESHOLD=10
BACKTEST_FAILURE_THRESHOLD=-20
