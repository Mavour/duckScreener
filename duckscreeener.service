[Unit]
Description=DuckScreener Crypto Agent
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/duckScreener
ExecStart=/home/duckScreener/venv/bin/python -m duckscreeener.main
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
